      setMounted(true);
    };
    init();
  }, []);

  if (!mounted) {
    return (
      <button
        type="button"
        className="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-dark-border bg-dark-surface text-text-primary transition"
        aria-label="Загрузка..."
        disabled
